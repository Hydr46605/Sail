SAIL_REGISTRY_HOST=127.0.0.1
SAIL_REGISTRY_PORT=8787
SAIL_REGISTRY_DATABASE_URL=postgres://sail:sail_dev_password@127.0.0.1:15432/sail
SAIL_REGISTRY_STATE_BACKEND=memory
SAIL_REGISTRY_ID=sail-local
SAIL_REGISTRY_NAME=Sail Local Registry
SAIL_REGISTRY_API_URL=http://127.0.0.1:8787
SAIL_REGISTRY_AUTH_URL=http://127.0.0.1:8787/auth/minecraft
SAIL_REGISTRY_TERMS_URL=http://127.0.0.1:8787/terms
SAIL_REGISTRY_PRIVACY_URL=http://127.0.0.1:8787/privacy
SAIL_REGISTRY_TRUST_STATUS=self_hosted
SAIL_REGISTRY_PUBLIC_KEY_PINNING=true
SAIL_REGISTRY_SIGNING_KEY_SOURCE=dev
SAIL_REGISTRY_ALLOW_DEV_SIGNING_KEY=false
SAIL_REGISTRY_SIGNING_KEY_ROTATION=off
# For self-hosted PostgreSQL or staging, use source=file or source=env.
# SAIL_REGISTRY_SIGNING_KEY_SOURCE=file
# SAIL_REGISTRY_SIGNING_KEY_FILE=/run/secrets/sail-registry-signing-key.jwk.json
# SAIL_REGISTRY_JWK_KID=
# SAIL_REGISTRY_JWK_X=
# SAIL_REGISTRY_JWK_Y=
# SAIL_REGISTRY_JWK_D=
SAIL_BLOCK_PREMIUM_NAMES_FOR_LOCAL=true
SAIL_MOJANG_PROFILE_API_URL=https://api.mojang.com
SAIL_MOJANG_LOOKUP_TIMEOUT_MS=2500
SAIL_PREMIUM_NAME_POSITIVE_CACHE_SECONDS=86400
SAIL_PREMIUM_NAME_NEGATIVE_CACHE_SECONDS=60
SAIL_OAUTH_DEV_ENABLED=false
SAIL_OAUTH_DISCORD_ENABLED=false
SAIL_OAUTH_DISCORD_CLIENT_ID=
SAIL_OAUTH_DISCORD_CLIENT_SECRET=
SAIL_OAUTH_DISCORD_REDIRECT_URI=http://127.0.0.1:8787/auth/discord/callback
