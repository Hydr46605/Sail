{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://protocol.sailmc.net/schemas/error.v1.schema.json",
  "title": "Sail Error v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "error"],
  "properties": {
    "protocol_version": {
      "const": "sail-protocol-v1"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "audience", "http_status", "retryable", "correlation_id"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{2,63}$"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 240
        },
        "audience": {
          "type": "string",
          "enum": ["player", "admin", "operator", "developer"]
        },
        "http_status": {
          "type": "integer",
          "minimum": 400,
          "maximum": 599
        },
        "retryable": {
          "type": "boolean"
        },
        "correlation_id": {
          "type": "string",
          "pattern": "^corr_[A-Za-z0-9_-]{8,96}$"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}

