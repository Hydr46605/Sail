{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://protocol.sailmc.net/schemas/server.v1.schema.json",
  "title": "Sail Server v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "registry_id",
    "server_id",
    "display_name",
    "registry_mode",
    "allowed_claim_types",
    "session_reuse_policy",
    "privacy_mode",
    "status",
    "public_listing"
  ],
  "properties": {
    "protocol_version": {
      "const": "sail-protocol-v1"
    },
    "registry_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{1,62}[a-z0-9]$"
    },
    "server_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{1,62}[a-z0-9]$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "registry_mode": {
      "type": "string",
      "enum": ["global", "self_hosted", "hybrid"]
    },
    "allowed_claim_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["MINECRAFT_VERIFIED", "SAIL_GLOBAL", "FEDERATED_TRUSTED", "LOCAL_SOFT", "SOCIAL_ONLY"]
      }
    },
    "session_reuse_policy": {
      "type": "string",
      "enum": ["off", "same_registry", "allowlisted_servers", "global_trusted"]
    },
    "privacy_mode": {
      "type": "string",
      "enum": ["minimal", "standard", "audit_full"]
    },
    "status": {
      "type": "string",
      "enum": ["active", "disabled", "suspended"]
    },
    "public_listing": {
      "type": "boolean"
    },
    "last_heartbeat_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  }
}
